<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NordSampleManager.ViewModels"
        xmlns:svc="using:NordSampleManager.Services"
        x:Class="NordSampleManager.Views.InstallSlotDialog"
        x:DataType="vm:InstallSlotDialogViewModel"
        Title="Install to Device"
        Width="420" Height="320"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <Grid RowDefinitions="*,Auto" Margin="16">

    <StackPanel Grid.Row="0" Spacing="12">

      <!-- Name -->
      <StackPanel Spacing="4">
        <TextBlock Text="Name on device" FontWeight="SemiBold"/>
        <TextBox Text="{Binding SoundName}" MaxLength="16"/>
      </StackPanel>

      <!-- Piano: size + category + slot -->
      <StackPanel Spacing="4" IsVisible="{Binding IsPiano}">
        <TextBlock Text="Download quality" FontWeight="SemiBold"/>
        <ComboBox ItemsSource="{Binding DownloadOptions}"
                  SelectedItem="{Binding SelectedOption}"
                  HorizontalAlignment="Stretch">
          <ComboBox.ItemTemplate>
            <DataTemplate DataType="svc:PianoDownloadOption">
              <TextBlock>
                <Run Text="{Binding Size}"/>
                <Run Text=" — "/>
                <Run Text="{Binding FileSize}"/>
                <Run Text=" (v"/>
                <Run Text="{Binding VersionName}"/>
                <Run Text=")"/>
              </TextBlock>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </StackPanel>

      <StackPanel Spacing="4" IsVisible="{Binding IsPiano}">
        <TextBlock Text="Destination" FontWeight="SemiBold"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <ComboBox ItemsSource="{Binding CategoryNames}"
                    SelectedIndex="{Binding SelectedCategoryIndex}"
                    Width="140"/>
          <NumericUpDown Minimum="0" Maximum="19" Increment="1"
                         Value="{Binding SelectedPianoSlot}"
                         HorizontalAlignment="Left" Width="80"/>
        </StackPanel>
      </StackPanel>

      <!-- Sample: slot -->
      <StackPanel Spacing="4" IsVisible="{Binding !IsPiano}">
        <TextBlock Text="Destination slot (0–399)" FontWeight="SemiBold"/>
        <NumericUpDown Minimum="0" Maximum="399" Increment="1"
                       Value="{Binding SelectedSampleSlot}"
                       HorizontalAlignment="Left" Width="100"/>
      </StackPanel>

      <!-- Overwrite warning -->
      <TextBlock Text="{Binding OverwriteWarning}"
                 IsVisible="{Binding IsOverwrite}"
                 Foreground="OrangeRed"
                 FontSize="11"/>
    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8"
                HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="Cancel" Click="OnCancel" IsCancel="True"/>
      <Button Content="{Binding ConfirmLabel}"
              Click="OnInstall" IsDefault="True"/>
    </StackPanel>

  </Grid>
</Window>
