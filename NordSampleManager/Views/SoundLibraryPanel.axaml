<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NordSampleManager.ViewModels"
             xmlns:svc="using:NordSampleManager.Services"
             x:Class="NordSampleManager.Views.SoundLibraryPanel"
             x:DataType="vm:SoundLibraryViewModel">
  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

    <!-- Header -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
      <TextBlock Grid.Column="0"
                 Text="Sound Library"
                 FontWeight="SemiBold" FontSize="14"
                 VerticalAlignment="Center"/>
      <Button Grid.Column="1"
              Content="↺ Refresh"
              Command="{Binding LoadCatalogCommand}"
              IsEnabled="{Binding !IsLoadingCatalog}"
              FontSize="11"
              Padding="6,3"
              ToolTip.Tip="Reload catalog from nordkeyboards.com"/>
    </Grid>

    <!-- Library type selector -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <RadioButton Content="Piano Library"
                   IsChecked="{Binding SelectedLibraryType, Converter={x:Static vm:StringEqualityConverter.Instance}, ConverterParameter=Piano}"
                   GroupName="LibraryType"/>
      <RadioButton Content="Sample Library"
                   IsChecked="{Binding SelectedLibraryType, Converter={x:Static vm:StringEqualityConverter.Instance}, ConverterParameter=Sample}"
                   GroupName="LibraryType"/>
    </StackPanel>

    <!-- Filter -->
    <TextBox Grid.Row="2"
             PlaceholderText="Filter…"
             Text="{Binding FilterText}"
             Margin="0,0,0,8"/>

    <!-- Content area -->
    <Grid Grid.Row="3">

      <!-- Piano: flat list -->
      <ListBox ItemsSource="{Binding FilteredPianos}"
               SelectedItem="{Binding SelectedItem}"
               IsVisible="{Binding SelectedLibraryType, Converter={x:Static vm:StringEqualityConverter.Instance}, ConverterParameter=Piano}">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="svc:LibraryCatalogEntry">
            <StackPanel Margin="2,4">
              <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding Description}"
                         FontSize="11" Opacity="0.65"
                         MaxLines="2" TextWrapping="Wrap"/>
              <WrapPanel Margin="0,4,0,0">
                <ItemsControl ItemsSource="{Binding Tags}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource SystemBaseLowColor}"
                              CornerRadius="3" Padding="4,1" Margin="0,0,4,2">
                        <TextBlock Text="{Binding}" FontSize="10"/>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </WrapPanel>
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <!-- Sample: category list + instrument list -->
      <Grid ColumnDefinitions="*,*"
            IsVisible="{Binding SelectedLibraryType, Converter={x:Static vm:StringEqualityConverter.Instance}, ConverterParameter=Sample}">
        <ListBox Grid.Column="0"
                 ItemsSource="{Binding SampleCategories}"
                 SelectedItem="{Binding SelectedCategory}">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="svc:LibraryCatalogEntry">
              <TextBlock Text="{Binding Title}" Margin="2,3" TextWrapping="Wrap" FontSize="12"/>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Column="1" RowDefinitions="*,Auto">
          <ListBox Grid.Row="0"
                   ItemsSource="{Binding FilteredInstruments}"
                   SelectedItem="{Binding SelectedItem}">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="svc:SampleInstrument">
                <StackPanel Margin="2,2">
                  <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12"
                             TextWrapping="Wrap"/>
                  <TextBlock FontSize="10" Opacity="0.65">
                    <Run Text="{Binding FileSize}"/>
                    <Run Text=" · v"/>
                    <Run Text="{Binding Version}"/>
                  </TextBlock>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <ProgressBar Grid.Row="1" IsIndeterminate="True"
                       IsVisible="{Binding IsLoadingInstruments}" Height="3"/>
        </Grid>
      </Grid>

      <!-- Empty / loading placeholder -->
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6"
                  IsVisible="{Binding IsLoadingCatalog}"
                  Opacity="0.5">
        <ProgressBar IsIndeterminate="True" Width="120" Height="4"/>
        <TextBlock Text="Loading catalog…" FontSize="11" HorizontalAlignment="Center"/>
      </StackPanel>

    </Grid>

    <!-- Bottom bar: selected item info + action buttons -->
    <Border Grid.Row="4" Margin="0,8,0,0"
            Padding="8"
            BorderBrush="{DynamicResource SystemBaseLowColor}"
            BorderThickness="0,1,0,0">
      <StackPanel Spacing="6">

        <!-- Status message (loading info, errors) -->
        <TextBlock Text="{Binding StatusMessage}" FontSize="11" Opacity="0.65"
                   TextWrapping="Wrap" MaxLines="2"
                   IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}"/>

        <!-- No selection placeholder -->
        <TextBlock Text="Select a sound above to install it"
                   FontSize="11" Opacity="0.45" HorizontalAlignment="Center"
                   Margin="0,4"
                   IsVisible="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNull}}"/>

        <!-- Action buttons (visible when item is selected) -->
        <StackPanel Spacing="6"
                    IsVisible="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}">
          <Button Content="⬇  Transfer to Instrument"
                  Click="OnTransferClick"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  FontWeight="Medium"
                  ToolTip.Tip="Download this sound and install it into the next available empty slot"/>
          <Button Content="⇄  Substitute Selected Sound"
                  Click="OnSubstituteClick"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  ToolTip.Tip="Replace the sound currently selected in the main list with this one"/>
        </StackPanel>

      </StackPanel>
    </Border>

  </Grid>
</UserControl>
