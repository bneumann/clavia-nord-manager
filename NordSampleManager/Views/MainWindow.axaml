<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NordSampleManager.ViewModels"
        xmlns:views="using:NordSampleManager.Views"
        x:Class="NordSampleManager.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1100" Height="720"
        Title="Nord Sample Manager">
  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0" Padding="12,10" Background="{DynamicResource SystemRegionBrush}">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <Button Content="Connect &amp; load"
                Command="{Binding ConnectAndLoadCommand}"
                IsEnabled="{Binding CanConnect}"/>
        <Button Content="Reload"
                Command="{Binding ReloadCommand}"
                IsEnabled="{Binding CanReload}"/>
        <Button Content="Rename…"
                Command="{Binding RenameCommand}"
                IsEnabled="{Binding CanRename}"/>
        <Button Content="Export…"
                Command="{Binding ExportCommand}"
                IsEnabled="{Binding CanExport}"/>
        <Button Content="Delete…"
                Command="{Binding DeleteCommand}"
                IsEnabled="{Binding CanDelete}"/>
        <Button Content="Upload…"
                Command="{Binding UploadCommand}"
                IsEnabled="{Binding CanUpload}"/>
        <Separator Width="1"/>
        <ToggleButton Content="Sound Library"
                      IsChecked="{Binding SoundLibraryVisible}"/>
        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"/>
        <ProgressBar IsIndeterminate="True" Width="120"
                     IsVisible="{Binding IsBusy}" VerticalAlignment="Center"/>
      </StackPanel>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="200,*,320,Auto">
      <!-- Left rail: category list + storage widget -->
      <Grid Grid.Column="0" RowDefinitions="*,Auto">
        <ListBox Grid.Row="0"
                 Margin="8"
                 ItemsSource="{Binding Categories}"
                 SelectedItem="{Binding SelectedCategory}">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:CategoryViewModel">
              <StackPanel Margin="2,4">
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Subtitle}" FontSize="11" Opacity="0.7"/>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- Storage pie chart — visible when piano library stats are available -->
        <Border Grid.Row="1"
                IsVisible="{Binding StorageVisible}"
                Margin="8,0,8,8" Padding="8"
                BorderBrush="{DynamicResource SystemBaseLowColor}"
                BorderThickness="1" CornerRadius="4">
          <StackPanel Spacing="4">
            <views:StoragePieControl
                UsedFraction="{Binding StorageUsedFraction}"
                Height="110"/>
            <TextBlock Text="{Binding StorageUsedText}"
                       FontSize="11" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding StorageFreeText}"
                       FontSize="11" HorizontalAlignment="Center" Opacity="0.7"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- Center: list of entries in selected category -->
      <Border Grid.Column="1" Margin="0,8" BorderBrush="{DynamicResource SystemBaseLowColor}" BorderThickness="1,0">
        <Grid RowDefinitions="Auto,*">
          <TextBox Grid.Row="0"
                   Margin="8,8,8,4"
                   PlaceholderText="Filter…"
                   Text="{Binding SelectedCategory.FilterText}"
                   IsEnabled="{Binding SelectedCategory, Converter={x:Static ObjectConverters.IsNotNull}}"/>
          <DataGrid Grid.Row="1"
                    Name="ProgramsGrid"
                    ItemsSource="{Binding SelectedCategory.FilteredEntries}"
                    SelectedItem="{Binding SelectedCategory.SelectedEntry}"
                    IsReadOnly="True"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    AutoGenerateColumns="False"
                    DragDrop.AllowDrop="True">
            <DataGrid.Columns>
              <DataGridTemplateColumn Width="28" Header="">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="⠿" FontSize="14"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               Cursor="SizeAll"
                               PointerPressed="OnGripPointerPressed"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="#"    Binding="{Binding Index}" Width="60"/>
              <DataGridTextColumn Header="Kind" Binding="{Binding Kind}"  Width="180"/>
              <DataGridTextColumn Header="Name" Binding="{Binding Name}"  Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>

      <!-- Right: detail pane -->
      <Border Grid.Column="2" Margin="8" Padding="12"
              BorderBrush="{DynamicResource SystemBaseLowColor}" BorderThickness="1" CornerRadius="4">
        <Grid RowDefinitions="Auto,Auto,*">
          <TextBlock Grid.Row="0" Text="Detail" FontWeight="SemiBold" FontSize="13"/>
          <TextBlock Grid.Row="1" Text="{Binding DetailHeader}" FontSize="16" Margin="0,8,0,4"/>
          <ScrollViewer Grid.Row="2">
            <TextBlock Text="{Binding DetailBody}"
                       TextWrapping="Wrap"
                       FontFamily="Inter, Cascadia Mono, Consolas, monospace"
                       FontSize="12"/>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- Sound library panel (collapsible) -->
      <Border Grid.Column="3"
              IsVisible="{Binding SoundLibraryVisible}"
              Width="380"
              BorderBrush="{DynamicResource SystemBaseLowColor}"
              BorderThickness="1,0,0,0">
        <views:SoundLibraryPanel
            Margin="8"
            DataContext="{Binding SoundLibrary}"
            InstallRequested="OnSoundLibraryInstallRequested"/>
      </Border>
    </Grid>
  </Grid>
</Window>
